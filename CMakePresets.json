{
  "version": 6,
  "vendor": {
    "robotics_rt_demo": {}
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "description": "Base preset with Conan toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/build/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with UBSAN instrumentation",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build (optimized)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Release with Debug Info",
      "description": "Release build with debug symbols",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "release",
      "configurePreset": "release",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo",
      "inheritConfigureEnvironment": true
    }
  ]
}